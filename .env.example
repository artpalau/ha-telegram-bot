# Copy this file to .env and fill in your values
# Never commit .env to git

# Home Assistant built-in MCP server URL (Streamable HTTP transport)
# Found in HA under Settings → Integrations → Model Context Protocol
# The private token is embedded in the URL — treat it like a password
HA_MCP_URL=http://192.168.0.51:9583/private_your_token_here

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Your Telegram user ID (numeric) — only this user can control the bot
# Find your ID by messaging @userinfobot on Telegram
TELEGRAM_ALLOWED_USER_IDS=123456789

# Ollama model to use (must support tool calling)
OLLAMA_MODEL=qwen3.5:9b
