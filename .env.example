# Copy this file to .env and fill in your values
# Never commit .env to git

# Home Assistant MCP server URL
HA_MCP_URL=http://192.168.0.51:8123/mcp_server/sse

# Home Assistant Long-Lived Access Token
# Get one at: http://192.168.0.51:8123/profile (scroll to bottom)
HA_TOKEN=your_ha_token_here

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Your Telegram user ID (numeric) — only this user can control the bot
# Find your ID by messaging @userinfobot on Telegram
TELEGRAM_ALLOWED_USER_IDS=123456789

# Ollama model to use (must support tool calling)
OLLAMA_MODEL=llama3.2
