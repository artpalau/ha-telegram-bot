# Copy this file to .env and fill in your values
# Never commit .env to git

# Home Assistant connection — use your Nabu Casa URL for remote access
# or http://192.168.0.51:8123 for local-only access
HOMEASSISTANT_URL=https://your-instance.ui.nabu.casa

# Home Assistant Long-Lived Access Token
# Get one at: your-ha-instance/profile (scroll to bottom)
HOMEASSISTANT_TOKEN=your_ha_token_here

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Your Telegram user ID (numeric) — only this user can control the bot
# Find your ID by messaging @userinfobot on Telegram
TELEGRAM_ALLOWED_USER_IDS=123456789

# Ollama model to use (must support tool calling)
OLLAMA_MODEL=llama3.2
